{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI: Uvicorn",
            "type": "debugpy",
            "request": "launch",
            "python": "/home/damian/.micromamba/envs/agentic-trading/bin/python",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--reload",
                "--host",
                "127.0.0.1",
                "--port",
                "8000"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Pytest: all tests",
            "type": "debugpy",
            "request": "launch",
            "python": "/home/damian/.micromamba/envs/agentic-trading/bin/python",
            "module": "pytest",
            "args": [
                "test",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Pytest: current file",
            "type": "debugpy",
            "request": "launch",
            "python": "/home/damian/.micromamba/envs/agentic-trading/bin/python",
            "module": "pytest",
            "args": [
                "${file}",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        }
    ]
}
